<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bg_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@color/bg_card">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:id="@+id/imgDetailAvatar"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_avatar_circle" />

                <View
                    android:id="@+id/viewDetailStatusDot"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/dot_green" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvDetailUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <!-- Role badge -->
            <TextView
                android:id="@+id/tvDetailRoleBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginBottom="8dp" />

            <!-- Activity status -->
            <TextView
                android:id="@+id/tvDetailActivityStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.05" />

        </LinearLayout>

        <!-- ── Quick stats row ─────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@color/bg_elevated">

            <!-- Level -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_purple"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LEVEL"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- XP -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailXp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent_cyan"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="XP"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <!-- XP progress in level -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvDetailXpProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/matrix_green"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="monospace" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="IN LEVEL"
                    android:textColor="@color/text_disabled"
                    android:textSize="10sp"
                    android:letterSpacing="0.1" />

            </LinearLayout>

        </LinearLayout>

        <!-- ── Identity section ────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="IDENTITY"
            android:textColor="@color/accent_cyan"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- User ID -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="User ID"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDetailId"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_disabled" android:textSize="12sp"
                        android:fontFamily="monospace" android:maxLines="1" android:ellipsize="middle" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <!-- Email -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Email"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDetailEmail"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="13sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <!-- Discord -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Discord"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDetailDiscord"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="13sp" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginStart="16dp" />

                <!-- Joined -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Joined"
                        android:textColor="@color/text_secondary" android:textSize="13sp" />
                    <TextView android:id="@+id/tvDetailJoined"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/text_primary" android:textSize="13sp" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Activity section ────────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ACTIVITY PROFILE"
            android:textColor="@color/accent_cyan"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="4dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Engagement label -->
                <TextView
                    android:id="@+id/tvDetailEngagement"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvDetailEngagementDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_marginBottom="12dp" />

                <!-- XP bar in detail -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Progress to next level"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                    <TextView
                        android:id="@+id/tvDetailXpLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_cyan"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />
                </LinearLayout>

                <ProgressBar
                    android:id="@+id/progressDetailXp"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="6dp"
                    android:max="1000"
                    android:progressTint="@color/accent_cyan"
                    android:progressBackgroundTint="@color/bg_elevated" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ── Moderation actions ───────────────────────────────────────── -->

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MODERATION ACTIONS"
            android:textColor="@color/accent_cyan"
            android:textSize="10sp"
            android:letterSpacing="0.12"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="18dp"
            android:paddingBottom="8dp" />

        <!-- Action buttons grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailRole"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Change Role"
                android:textSize="11sp"
                android:textColor="@color/accent_purple"
                app:strokeColor="@color/accent_purple"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailWarn"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Issue Warning"
                android:textSize="11sp"
                android:textColor="@color/status_warning"
                app:strokeColor="@color/status_warning"
                app:cornerRadius="10dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailMute"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Mute"
                android:textSize="11sp"
                android:textColor="@color/accent_blue"
                app:strokeColor="@color/accent_blue"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailSuspend"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Suspend"
                android:textSize="11sp"
                android:textColor="@color/status_warning"
                app:strokeColor="@color/status_warning"
                app:cornerRadius="10dp" />

        </LinearLayout>

        <!-- Ban — full width, red -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetailBan"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="24dp"
            android:text="Ban User"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            app:backgroundTint="@color/status_error"
            app:cornerRadius="10dp" />

    </LinearLayout>

</ScrollView>
